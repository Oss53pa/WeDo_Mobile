# The Gradle wrapper script MUST stay LF or the Linux CI runner can't execute it.
gradlew            text eol=lf
*.sh               text eol=lf

# Windows scripts stay CRLF
gradlew.bat        text eol=crlf
*.bat              text eol=crlf

# Binary assets — never normalize
*.jar              binary
*.keystore         binary
*.png              binary
*.jpg              binary
*.jpeg             binary
*.gif              binary
*.webp             binary
*.ttf              binary
*.otf              binary
